# Firecrawl Configuration
FIRECRAWL_API_KEY=

# OpenRouter Configuration
# Get a free API key at https://openrouter.ai/ — no credit card required.
# New accounts get a small free allowance; many :free models cost $0.
OPENROUTER_API_KEY=

# Primary model (tried first). Uses your OpenRouter credits if the model isn't free.
OPENROUTER_MODEL=openai/gpt-4o-mini

# Free fallback when primary fails or runs out of credits (429/502/503).
# openrouter/free picks a random free model; or set a specific one like google/gemma-3-27b-it:free
OPENROUTER_FREE_MODEL=openrouter/free

# Vercel AI Gateway / OpenAI Configuration (Secondary Fallback)
# AI_GATEWAY_API_KEY=
# OPENAI_API_KEY=
